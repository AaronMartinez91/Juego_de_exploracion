<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="B2ACT2Juego_de_exploracion.About"
             Title="Acerca de"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="2*, *">

        <Grid Grid.Row="0">
            <Image Source="h07_camara_secreta.png"
                   Aspect="AspectFill"/>
            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="8"
                                 Padding="20">
                <Label Text="LA MANSIÓN"
                       FontSize="36"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"/>
                <Label Text="v1.0 · 2026"
                       FontSize="14"
                       TextColor="#CCBBAA"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>
        </Grid>

        <VerticalStackLayout Grid.Row="1"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="16"
                             Padding="40,0">

            <Label Text="Desarrollado por Aarón Martínez"
                   FontSize="16"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"/>

            <Label Text="Mi primer juego y aplicación desarrollada en .NET MAUI. Un juego de exploración de texto ambientado en una misteriosa mansión."
                   FontSize="14"
                   HorizontalTextAlignment="Center"/>

            <Label Text="¿Encontraste algún bug o tienes alguna duda? No dudes en contactarme a través de LinkedIn o GitHub."
                   FontSize="13"
                   TextColor="Gray"
                   HorizontalTextAlignment="Center"/>

        </VerticalStackLayout>

    </Grid>

</ContentPage>