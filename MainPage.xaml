<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="B2ACT2Juego_de_exploracion.MainPage"
             Title=""
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="2*, *">

        <Grid Grid.Row="0">

            <Image Source="h01_porche.png"
                   Aspect="AspectFill"/>

            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="8">

                <Label Text="LA MANSIÓN"
                       FontSize="36"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"/>

                <Label Text="— un juego de exploración —"
                       FontSize="14"
                       TextColor="#CCBBAA"
                       HorizontalTextAlignment="Center"/>

            </VerticalStackLayout>

        </Grid>

        <VerticalStackLayout Grid.Row="1"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="12"
                             Padding="40,0">

            <Button x:Name="btnNuevaPartida"
                    Text="Nueva partida"
                    BackgroundColor="Black"
                    TextColor="White"
                    CornerRadius="4"
                    HeightRequest="50"
                    WidthRequest="250"
                    Clicked="btnNuevaPartida_Clicked"/>

            <Button x:Name="btnContinuar"
                    Text="Continuar"
                    BackgroundColor="Black"
                    TextColor="White"
                    CornerRadius="4"
                    HeightRequest="50"
                    WidthRequest="250"
                    IsEnabled="False"
                    Clicked="btnContinuar_Clicked"/>

            <Button x:Name="btnAcercaDe"
                    Text="Acerca de"
                    BackgroundColor="Black"
                    TextColor="White"
                    CornerRadius="4"
                    HeightRequest="50"
                    WidthRequest="250"
                    Clicked="btnAcercaDe_Clicked"/>

        </VerticalStackLayout>

    </Grid>

</ContentPage>