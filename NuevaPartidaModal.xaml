<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="B2ACT2Juego_de_exploracion.NuevaPartidaModal"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*, Auto"
      Padding="30"
      BackgroundColor="#26201b">

        <VerticalStackLayout Grid.Row="0"
                         VerticalOptions="Center"
                         HorizontalOptions="Center"
                         Spacing="20">

            <Label Text="¿Empezar de nuevo?"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalTextAlignment="Center"/>

            <Label Text="Ya tienes una partida guardada. Si empiezas de nuevo perderás todo tu progreso."
               FontSize="14"
               HorizontalTextAlignment="Center"/>

            <Grid ColumnDefinitions="*, *"
              ColumnSpacing="12"
              Margin="0,20,0,0">

                <Button Grid.Column="0"
                    x:Name="btnCancelar"
                    Text="Cancelar"
                    BackgroundColor="Black"
                    TextColor="#D0D0D0"
                    Clicked="btnCancelar_Clicked"/>

                <Button Grid.Column="1"
                    x:Name="btnConfirmar"
                    Text="Sí, empezar"
                    BackgroundColor="#5C2020"
                    TextColor="#D0D0D0"
                    Clicked="btnConfirmar_Clicked"/>

            </Grid>

        </VerticalStackLayout>

    </Grid>

</ContentPage>